# ==========================================================
# Cell 18 : Top-K CHUNK Retrieval from Knowledge Graph (No LLM)
# Output: {"predictions": [{"data": [{content, title, reference}]}]}
# ==========================================================
import re
import math
import json
import hashlib
from collections import Counter

query = """
Why is being a SQEP important in the context described in the document?
"""

TOP_K              = 10
CANDIDATE_NODES    = 60
CHUNK_SIZE         = 1200
MIN_CHUNK_CHARS    = 150
MAX_CHUNKS_PER_DOC = 2      # hard cap, never relaxed
JACCARD_THRESHOLD  = 0.30   # near-duplicate cutoff (lower = stricter)
CONTAIN_THRESHOLD  = 0.55   # containment cutoff
SHINGLE_N          = 6      # word n-gram size for similarity

# ----------------------------------------------------------
# Tokenizing — no stopword list, IDF handles common words
# ----------------------------------------------------------
def tokens(text):
    return re.findall(r'[a-z0-9]+', str(text).lower())

def token_set(text):
    return set(tokens(text))

def shingles(text, n=SHINGLE_N):
    """Word n-grams — catches passages that share long runs of text."""
    w = tokens(text)
    return {" ".join(w[i:i+n]) for i in range(max(0, len(w) - n + 1))}

def norm_hash(text):
    """Exact-duplicate signature, whitespace/punctuation insensitive."""
    return hashlib.md5(" ".join(tokens(text)).encode()).hexdigest()

# ----------------------------------------------------------
# IDF over loaded documents
# ----------------------------------------------------------
def build_idf(graph):
    df, n_docs = Counter(), 0
    for _, a in graph.nodes(data=True):
        c = a.get("content")
        if not c:
            continue
        n_docs += 1
        for w in set(tokens((a.get("title","") or "") + " " + c)):
            df[w] += 1
    return {w: math.log((n_docs + 1) / (c + 1)) + 1.0 for w, c in df.items()}, n_docs

IDF, N_DOCS = build_idf(KG)

def weighted_overlap(query_terms, text_tokens):
    return sum(IDF.get(w, 1.0) for w in query_terms if w in text_tokens)

# ----------------------------------------------------------
# Query terms + phrases
# ----------------------------------------------------------
q_tokens  = tokens(query)
q_terms   = set(q_tokens)
q_phrases = [" ".join(q_tokens[i:i+2]) for i in range(len(q_tokens)-1)]
q_weight  = sum(IDF.get(w, 1.0) for w in q_terms) or 1.0

print("Query terms by IDF (higher = more distinctive):")
for w in sorted(q_terms, key=lambda x: IDF.get(x, 1.0), reverse=True)[:8]:
    print(f"   {w:<20} {IDF.get(w, 1.0):.2f}")
print()

# ----------------------------------------------------------
# Cleaning
# ----------------------------------------------------------
def clean_text(t):
    t = t or ''
    t = re.sub(r'\(%[^%]*%\)', ' ', t)
    t = re.sub(r'\{\{[^}]*\}\}', ' ', t)
    t = re.sub(r'<[^>]{1,200}>', ' ', t)
    t = re.sub(r'\[\[([^\]>]+)>>[^\]]+\]\]', r'\1', t)
    t = re.sub(r'\(doc:[^)]+\)', ' ', t)
    t = re.sub(r'https?://\S+', ' ', t)
    t = re.sub(r'[ \t]{2,}', ' ', t)
    return re.sub(r'\n{3,}', '\n\n', t).strip()

def split_into_chunks(text, max_chars=CHUNK_SIZE):
    text = clean_text(text)
    if not text:
        return []
    chunks, buf = [], ""
    for para in re.split(r'\n\s*\n', text):
        para = para.strip()
        if not para:
            continue
        if len(para) > max_chars:
            if buf:
                chunks.append(buf.strip()); buf = ""
            for i in range(0, len(para), max_chars):
                chunks.append(para[i:i + max_chars].strip())
        elif len(buf) + len(para) + 2 <= max_chars:
            buf = (buf + "\n\n" + para) if buf else para
        else:
            chunks.append(buf.strip()); buf = para
    if buf:
        chunks.append(buf.strip())
    return [c for c in chunks if len(c) >= MIN_CHUNK_CHARS]

# ----------------------------------------------------------
# Candidate nodes via graph traversal
# ----------------------------------------------------------
def candidate_nodes(graph, limit=CANDIDATE_NODES):
    scores = []
    for n, a in graph.nodes(data=True):
        if not a.get("content"):
            continue
        t_tok = token_set(a.get("title","") or "")
        c_tok = token_set((a.get("content","") or "")[:6000])
        s = weighted_overlap(q_terms, t_tok) * 3 + weighted_overlap(q_terms, c_tok)
        if s > 0:
            scores.append((n, s))
    scores.sort(key=lambda x: x[1], reverse=True)
    start = [n for n, _ in scores[:5]]

    collected = {n: 0 for n in start}
    def explore(frontier, hop):
        nxt = set()
        for cur in frontier:
            for nb in set(graph.successors(cur)) | set(graph.predecessors(cur)):
                if nb not in collected:
                    collected[nb] = hop
                    nxt.add(nb)
        return nxt
    explore(explore(set(start), 1), 2)

    def rank(n):
        a = graph.nodes[n]
        tok = token_set((a.get("title","") or "") + " " + (a.get("content","") or "")[:6000])
        return (weighted_overlap(q_terms, tok) * 5
                + (3 - min(collected.get(n, 99), 3)) * 2
                + a.get("degree", graph.degree(n)) * 0.1)

    ranked = [n for n in sorted(collected, key=rank, reverse=True)
              if graph.nodes[n].get("content")]
    print(f"Start nodes: {len(start)} | traversed to {len(collected)} nodes")
    return [(n, collected.get(n, 99)) for n in ranked[:limit]]

# ----------------------------------------------------------
# Score all chunks, then select with layered dedup
# ----------------------------------------------------------
def retrieve_chunks(graph, top_k=TOP_K):
    scored = []

    for node, hop in candidate_nodes(graph):
        a     = graph.nodes[node]
        title = a.get("title", node)
        t_tok = token_set(title)

        for chunk in split_into_chunks(a.get("content", "")):
            c_tok = token_set(chunk)
            w_ov  = weighted_overlap(q_terms, c_tok)
            if w_ov == 0:
                continue
            low         = chunk.lower()
            phrase_hits = sum(1 for p in q_phrases if p in low)
            tf = sum(min(low.count(w), 3) * IDF.get(w, 1.0) for w in q_terms if w in c_tok)
            score = ((w_ov / q_weight) * 25 + tf * 1.5 + phrase_hits * 8
                     + weighted_overlap(q_terms, t_tok) * 3
                     + (3 - min(hop, 3)) * 1.5)
            scored.append({"content": chunk, "title": title,
                           "reference": node, "_score": score})

    # best-first so the strongest member of a duplicate group wins
    scored.sort(key=lambda x: x["_score"], reverse=True)

    chosen        = []
    seen_hashes   = set()
    seen_shingles = []      # list of shingle sets
    seen_tokens   = []      # list of token sets
    per_doc       = {}
    dropped       = 0

    for c in scored:
        if len(chosen) >= top_k:
            break

        ref = c["reference"]
        if per_doc.get(ref, 0) >= MAX_CHUNKS_PER_DOC:
            continue

        text = c["content"]

        # layer 1 — exact duplicate
        h = norm_hash(text)
        if h in seen_hashes:
            dropped += 1
            continue

        # layer 2 — shared long word runs (Jaccard on n-grams)
        sh = shingles(text)
        if sh and any(
            len(sh & prev) / len(sh | prev) > JACCARD_THRESHOLD
            for prev in seen_shingles
        ):
            dropped += 1
            continue

        # layer 3 — containment (short chunk inside a longer one)
        ts = token_set(text)
        if ts and any(
            len(ts & prev) / min(len(ts), len(prev)) > CONTAIN_THRESHOLD
            for prev in seen_tokens
        ):
            dropped += 1
            continue

        chosen.append(c)
        seen_hashes.add(h)
        seen_shingles.append(sh)
        seen_tokens.append(ts)
        per_doc[ref] = per_doc.get(ref, 0) + 1

    print(f"Chunks scored: {len(scored)} | duplicates dropped: {dropped} "
          f"| selected: {len(chosen)}\n")
    return chosen

chunks = retrieve_chunks(KG, top_k=TOP_K)

# ----------------------------------------------------------
# Response payload
# ----------------------------------------------------------
response = {
    "predictions": [{
        "data": [
            {"content": c["content"], "title": c["title"], "reference": c["reference"]}
            for c in chunks
        ]
    }]
}

print("Status Code: 200\n")
print("Response:")
print(json.dumps(response, indent=2, ensure_ascii=False))
