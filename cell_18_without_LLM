# ----------------------------------------------------------
# Build the response payload  ->  predictions / data / chunks
# ----------------------------------------------------------
def build_response(candidates, max_chars=MAX_CONTENT_CHARS):
    data = []
    for c in candidates:
        content = c.get("content", "") or ""
        if max_chars:
            content = content[:max_chars]
        data.append({
            "content":   content,
            "title":     c.get("title", ""),
            "reference": c.get("reference", ""),
        })
    return {"predictions": [{"data": data}]}

