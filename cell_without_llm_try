# ==========================================================
# Cell 18 : Top-K CHUNK Retrieval (No LLM)
# Splits node content into chunks, ranks CHUNKS against the query,
# returns the best TOP_K chunks.
# Output:
# {"predictions": [ {"data": [ {content, title, reference}, ... ] } ]}
# ==========================================================
import re
import json

# ----------------------------------------------------------
# User Query
# ----------------------------------------------------------
query = """
Why is being a SQEP important in the context described in the document?
"""

# ----------------------------------------------------------
# Configuration
# ----------------------------------------------------------
TOP_K            = 10     # number of CHUNKS to return
CANDIDATE_NODES  = 40     # how many nodes to pull chunks from
CHUNK_SIZE       = 1200   # max chars per chunk
CHUNK_OVERLAP    = 150    # overlap between hard-split chunks
MIN_CHUNK_CHARS  = 120    # ignore tiny fragments
CLEAN_WIKI_MARKUP = True  # strip (% ... %) macros, html tags
DROP_TABLE_CHUNKS = True  # drop chunks that are mostly table markup

# ----------------------------------------------------------
# Keyword extraction
# ----------------------------------------------------------
STOPWORDS = {"how","can","a","an","new","be","created","create","in","the","what",
             "is","of","to","and","for","on","it","does","typically","why","are",
             "with","this","that","from","by","as","at","or","we","i","you","being",
             "important","context","described","document"}

def get_keywords(text):
    return set(re.findall(r'[a-z0-9]+', str(text).lower())) - STOPWORDS

query_keywords = get_keywords(query)

# ----------------------------------------------------------
# Text cleaning  (removes the (% class="x165" %) noise)
# ----------------------------------------------------------
def clean_text(t):
    if not CLEAN_WIKI_MARKUP:
        return t
    t = re.sub(r'\(%[^%]*%\)', ' ', t)      # (% style="..." %) macros
    t = re.sub(r'\{\{[^}]*\}\}', ' ', t)    # {{macro}}
    t = re.sub(r'<[^>]{1,200}>', ' ', t)    # html tags
    t = re.sub(r'[ \t]{2,}', ' ', t)
    t = re.sub(r'\n{3,}', '\n\n', t)
    return t.strip()

def is_table_noise(chunk):
    if not DROP_TABLE_CHUNKS:
        return False
    pipes = chunk.count("|")
    return pipes > 15 and pipes > len(chunk) / 60

# ----------------------------------------------------------
# Chunking : heading-aware, then paragraph, then hard split
# ----------------------------------------------------------
def split_into_chunks(text, max_chars=CHUNK_SIZE, overlap=CHUNK_OVERLAP):
    text = clean_text(text or "")
    if not text:
        return []

    blocks = re.split(r'\n(?=#{1,6}\s)', text)      # keep markdown sections together
    chunks = []

    for block in blocks:
        block = block.strip()
        if not block:
            continue
        if len(block) <= max_chars:
            chunks.append(block)
            continue

        buf = ""
        for para in re.split(r'\n\s*\n', block):
            para = para.strip()
            if not para:
                continue
            if len(para) > max_chars:                # oversized paragraph -> hard split
                if buf:
                    chunks.append(buf.strip()); buf = ""
                step = max(1, max_chars - overlap)
                for i in range(0, len(para), step):
                    chunks.append(para[i:i + max_chars].strip())
            elif len(buf) + len(para) + 2 <= max_chars:
                buf = (buf + "\n\n" + para) if buf else para
            else:
                chunks.append(buf.strip())
                buf = para
        if buf:
            chunks.append(buf.strip())

    return [c for c in chunks if len(c) >= MIN_CHUNK_CHARS and not is_table_noise(c)]

# ----------------------------------------------------------
# Step 1 : find candidate NODES via the knowledge graph
# ----------------------------------------------------------
def retrieve_candidate_nodes(graph, query_kw, limit=CANDIDATE_NODES):
    node_scores = []
    for node, attr in graph.nodes(data=True):
        if not attr.get("content"):
            continue
        title   = attr.get("title", "") or ""
        content = attr.get("content", "") or ""
        score = len(query_kw & get_keywords(title)) * 3 + \
                len(query_kw & get_keywords(content[:4000]))
        if score > 0:
            node_scores.append((node, score))
    node_scores.sort(key=lambda x: x[1], reverse=True)
    start_nodes = [n for n, _ in node_scores[:3]]

    def neighbors_both(n):
        return set(graph.successors(n)) | set(graph.predecessors(n))

    collected = {s: 0 for s in start_nodes}
    def explore(frontier, hop):
        nxt = set()
        for cur in frontier:
            for nb in neighbors_both(cur):
                if nb not in collected:
                    collected[nb] = hop
                    nxt.add(nb)
        return nxt
    explore(explore(set(start_nodes), 1), 2)

    def node_rank(n):
        a = graph.nodes[n]
        kw  = len(query_kw & get_keywords((a.get("title","") or "") + " " +
                                          (a.get("content","") or "")[:4000]))
        hop = collected.get(n, 99)
        deg = a.get("degree", graph.degree(n))
        return kw * 5 + (3 - min(hop, 3)) * 2 + deg * 0.1

    ranked = [n for n in sorted(collected, key=node_rank, reverse=True)
              if graph.nodes[n].get("content")]
    return [(n, collected.get(n, 99)) for n in ranked[:limit]]

# ----------------------------------------------------------
# Step 2 : chunk every candidate node and score CHUNKS
# ----------------------------------------------------------
def retrieve_chunks(graph, query_kw, top_k=TOP_K):
    scored, seen = [], set()

    for node, hop in retrieve_candidate_nodes(graph, query_kw):
        attr      = graph.nodes[node]
        title     = attr.get("title", node)
        reference = attr.get("reference", node)
        title_kw  = query_kw & get_keywords(title)

        for chunk in split_into_chunks(attr.get("content", "")):
            key = chunk[:200]
            if key in seen:
                continue
            seen.add(key)

            chunk_low = chunk.lower()
            chunk_kw  = get_keywords(chunk)
            overlap   = query_kw & chunk_kw
            if not overlap:
                continue

            coverage = len(overlap) / max(1, len(query_kw))
            hits     = sum(chunk_low.count(w) for w in overlap)
            score = (len(overlap) * 5) + (coverage * 10) + min(hits, 12) * 0.5 \
                    + len(title_kw) * 3 + (3 - min(hop, 3)) * 1.5

            scored.append({
                "content":   chunk,
                "title":     title,
                "reference": reference,
                "_score":    round(score, 2),
            })

    scored.sort(key=lambda x: x["_score"], reverse=True)
    return scored[:top_k]

chunks = retrieve_chunks(KG, query_keywords, top_k=TOP_K)

# ----------------------------------------------------------
# Step 3 : build + print the response payload
# ----------------------------------------------------------
response = {"predictions": [{"data": [
    {"content": c["content"], "title": c["title"], "reference": c["reference"]}
    for c in chunks
]}]}

print("Status Code: 200\n")
print("Response:")
print(json.dumps(response, indent=2, ensure_ascii=False))
